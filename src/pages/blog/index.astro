---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客 | 希儿" description="希儿的博客：Web 开发、LeafVault、Astro 建站和智能车辆学习笔记。">
  <section class="py-16">
    <SectionTitle
      eyebrow="Blog"
      title="学习记录与开发日志"
    />

    <div class="space-y-5">
      {posts.map((post) => {
        const category = post.data.category ?? post.data.tags[0] ?? '博客';
        const keywords = post.data.tags.filter((tag) => tag !== category);
        const visibleKeywords = keywords.length > 0 ? keywords : post.data.tags;

        return (
          <a href={`/blog/${post.id}`} data-reveal class="glass-card group block rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-900/10">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-emerald-100/60 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-emerald-900/5">{category}</span>
                  <span class="text-sm text-slate-500">{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
                </div>
                <h2 class="mt-3 text-2xl font-bold text-emerald-950 group-hover:text-emerald-700">{post.data.title}</h2>
                <p class="mt-3 leading-7 text-slate-600">{post.data.description}</p>
              </div>
              <div class="flex shrink-0 flex-wrap gap-2 sm:max-w-52 sm:justify-end">
                {visibleKeywords.map((tag) => <span class="rounded-full bg-emerald-50/80 px-3 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-900/5">{tag}</span>)}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
