---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionTitle from '@components/SectionTitle.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客 | 希儿" description="希儿的博客：Web 开发、LeafVault、Astro 建站和智能车辆学习笔记。">
  <section class="py-16">
    <SectionTitle
      eyebrow="Blog"
      title="学习记录与开发日志"
      description="使用 MDX 编写，适合长期沉淀开发过程、项目复盘和课程学习笔记。"
    />

    <div class="space-y-5">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} data-reveal class="glass-card group block rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-900/10">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-sm text-slate-500">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
              <h2 class="mt-2 text-2xl font-bold text-emerald-950 group-hover:text-emerald-700">{post.data.title}</h2>
              <p class="mt-3 leading-7 text-slate-600">{post.data.description}</p>
            </div>
            <div class="flex flex-wrap gap-2 sm:justify-end">
              {post.data.tags.map((tag) => <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">{tag}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
