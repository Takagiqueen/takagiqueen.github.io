---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import NatureBackground from '@components/NatureBackground.astro';
import BackToTop from '@components/BackToTop.astro';
import ScrollReveal from '@components/ScrollReveal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '希儿 | Personal Site',
  description = '一个关于 Web 开发、智能车辆、LeafVault 和学习记录的个人网站。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f3faf5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <NatureBackground />
    <Navbar />
    <main class="relative z-10 mx-auto min-h-screen w-full max-w-6xl px-5 pt-24 sm:px-8 lg:px-10">
      <slot />
    </main>
    <Footer />
    <BackToTop />
    <ScrollReveal />
  </body>
</html>
