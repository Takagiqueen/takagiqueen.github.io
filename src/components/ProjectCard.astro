---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  accent?: string;
}

const { title, description, tags = [], href = '#', accent = 'from-emerald-100 to-sky-100' } = Astro.props;
---

<a
  href={href}
  data-reveal
  class="group glass-card relative block overflow-hidden rounded-[1.75rem] p-5 transition duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10"
>
  <div class={`mb-5 h-40 rounded-[1.25rem] bg-gradient-to-br ${accent} p-5`}>
    <div class="flex h-full flex-col justify-between">
      <span class="w-fit rounded-full bg-white/65 px-3 py-1 text-xs font-semibold text-emerald-900 backdrop-blur">Project</span>
      <div>
        <div class="h-2 w-24 rounded-full bg-white/60 transition group-hover:w-32"></div>
        <div class="mt-3 h-2 w-36 rounded-full bg-white/50"></div>
      </div>
    </div>
  </div>

  <h3 class="text-xl font-bold tracking-tight text-emerald-950">{title}</h3>
  <p class="mt-3 min-h-16 leading-7 text-slate-600">{description}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">{tag}</span>
    ))}
  </div>
</a>
