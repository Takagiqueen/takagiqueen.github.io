---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  accent?: string;
}

const { title, description, tags = [], href = '#', accent = 'from-emerald-100 to-sky-100' } = Astro.props;
---

<a
  href={href}
  data-reveal
  class="group glass-card relative block overflow-hidden rounded-[1.75rem] p-5 transition duration-300 hover:-translate-y-2 hover:shadow-[0_28px_86px_rgba(6,78,59,0.15)]"
>
  <div class={`relative mb-5 h-40 overflow-hidden rounded-[1.25rem] border border-white/50 bg-gradient-to-br ${accent} p-5 shadow-inner shadow-white/40 ring-1 ring-white/35`}>
    <div class="absolute -right-8 -top-8 size-28 rounded-full bg-white/35 blur-2xl transition duration-500 group-hover:scale-125"></div>
    <div class="absolute bottom-0 left-0 h-16 w-full bg-gradient-to-t from-white/28 to-transparent"></div>
    <div class="relative flex h-full flex-col justify-between">
      <span class="w-fit rounded-full border border-white/50 bg-emerald-950/5 px-3 py-1 text-xs font-semibold text-emerald-950 shadow-sm backdrop-blur-md">Project</span>
      <div>
        <div class="h-2 w-24 rounded-full bg-emerald-950/10 transition group-hover:w-32 group-hover:bg-emerald-700/20"></div>
        <div class="mt-3 h-2 w-36 rounded-full bg-white/55"></div>
      </div>
    </div>
  </div>

  <h3 class="text-xl font-bold tracking-tight text-emerald-950">{title}</h3>
  <p class="mt-3 min-h-16 leading-7 text-slate-600">{description}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full bg-emerald-100/55 px-3 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-900/5 backdrop-blur">{tag}</span>
    ))}
  </div>
</a>
