---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  accent?: string;
  image?: string;
  imageAlt?: string;
  imageObjectPosition?: string;
}

const {
  title,
  description,
  tags = [],
  href = '#',
  accent = 'from-emerald-100 to-sky-100',
  image,
  imageAlt = `${title} 项目预览图`,
  imageObjectPosition = 'center',
} = Astro.props;
---

<a
  href={href}
  data-reveal
  class="project-card-link group block h-full rounded-[1.75rem]"
>
  <div data-project-card class="project-card glass-card relative flex h-full flex-col overflow-hidden rounded-[1.75rem] p-5">
    <span class="project-card-spotlight pointer-events-none absolute inset-0" aria-hidden="true"></span>

    <div class="project-card-content relative z-[1] flex h-full flex-col">
      <div class={`project-card-media relative mb-5 h-40 overflow-hidden rounded-[1.25rem] border border-white/50 bg-gradient-to-br ${accent} shadow-inner shadow-white/40 ring-1 ring-white/35 sm:h-44`}>
        {
          image ? (
            <>
              <img
                src={image}
                alt={imageAlt}
                loading="lazy"
                decoding="async"
                class="project-card-image size-full object-cover"
                style={`object-position: ${imageObjectPosition};`}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/22 via-emerald-950/0 to-white/10 transition duration-500 group-hover:from-emerald-950/12"></div>
              <span class="absolute left-4 top-4 w-fit rounded-full border border-white/60 bg-white/70 px-3 py-1 text-xs font-semibold text-emerald-950 shadow-sm backdrop-blur-md">
                Project
              </span>
            </>
          ) : (
            <div class="relative flex h-full flex-col justify-between p-5">
              <div class="absolute -right-8 -top-8 size-28 rounded-full bg-white/35 blur-2xl transition duration-500 group-hover:scale-125"></div>
              <div class="absolute bottom-0 left-0 h-16 w-full bg-gradient-to-t from-white/28 to-transparent"></div>
              <span class="relative w-fit rounded-full border border-white/50 bg-emerald-950/5 px-3 py-1 text-xs font-semibold text-emerald-950 shadow-sm backdrop-blur-md">Project</span>
              <div class="relative">
                <div class="h-2 w-24 rounded-full bg-emerald-950/10 transition group-hover:w-32 group-hover:bg-emerald-700/20"></div>
                <div class="mt-3 h-2 w-36 rounded-full bg-white/55"></div>
              </div>
            </div>
          )
        }
      </div>

      <h3 class="text-xl font-bold tracking-tight text-emerald-950">{title}</h3>
      <p class="mt-3 min-h-16 leading-7 text-slate-600">{description}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-emerald-100/55 px-3 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-900/5 backdrop-blur">{tag}</span>
        ))}
      </div>

      <span class="project-card-cta mt-auto inline-flex items-center gap-2 pt-5 text-sm font-semibold text-emerald-800">
        查看项目
        <svg class="project-card-arrow size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path>
          <path d="m13 6 6 6-6 6"></path>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .project-card {
    --project-pointer-x: 50%;
    --project-pointer-y: 50%;
    --project-rotate-x: 0deg;
    --project-rotate-y: 0deg;
    --project-image-x: 0px;
    --project-image-y: 0px;
    --project-lift: 0px;
    --project-scale: 1;
    transform: perspective(1000px) rotateX(var(--project-rotate-x)) rotateY(var(--project-rotate-y)) translate3d(0, var(--project-lift), 0) scale(var(--project-scale));
    transform-style: preserve-3d;
    transition:
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 220ms ease,
      box-shadow 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card-spotlight {
    background: radial-gradient(
      360px circle at var(--project-pointer-x) var(--project-pointer-y),
      rgba(255, 255, 255, 0.5),
      rgba(110, 231, 183, 0.16) 28%,
      transparent 66%
    );
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .project-card-media {
    transform: translateZ(0);
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card-image {
    transform: translate3d(var(--project-image-x), var(--project-image-y), 0) scale(1);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card-arrow {
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card-link:focus-visible {
    outline: none;
  }

  .project-card-link:focus-visible .project-card {
    box-shadow:
      0 0 0 3px rgba(5, 150, 105, 0.3),
      0 28px 86px rgba(6, 78, 59, 0.15);
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card-link:hover .project-card {
      --project-lift: -4px;
      border-color: rgba(167, 243, 208, 0.8);
      box-shadow:
        0 30px 88px rgba(6, 78, 59, 0.15),
        inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .project-card-link:hover .project-card-image {
      transform: translate3d(var(--project-image-x), var(--project-image-y), 0) scale(1.035);
    }

    .project-card-link:hover .project-card-arrow {
      transform: translateX(3px);
    }

    .project-card.is-pointer-active,
    .project-card.is-pointer-active .project-card-media,
    .project-card.is-pointer-active .project-card-image {
      will-change: transform;
    }

    .project-card.is-pointer-active .project-card-spotlight {
      opacity: 1;
    }

    .project-card.is-pointer-active .project-card-media {
      transform: translateZ(14px);
    }
  }

  @media (hover: none), (pointer: coarse) {
    .project-card-link:active .project-card {
      --project-scale: 0.985;
      transition-duration: 120ms;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transform: none !important;
    }

    .project-card,
    .project-card-media,
    .project-card-image,
    .project-card-arrow {
      transition-duration: 0.01ms !important;
    }

    .project-card-spotlight {
      display: none;
    }

    .project-card-link:hover .project-card-image,
    .project-card.is-pointer-active .project-card-media {
      transform: none;
    }
  }
</style>

<script>
  (function () {
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    function resetCard(card: HTMLElement) {
      card.classList.remove('is-pointer-active');
      card.style.setProperty('--project-pointer-x', '50%');
      card.style.setProperty('--project-pointer-y', '50%');
      card.style.setProperty('--project-rotate-x', '0deg');
      card.style.setProperty('--project-rotate-y', '0deg');
      card.style.setProperty('--project-image-x', '0px');
      card.style.setProperty('--project-image-y', '0px');
    }

    function initProjectCards() {
      document.querySelectorAll<HTMLElement>('[data-project-card]').forEach((card) => {
        if (card.dataset.pointerBound === 'true') return;
        card.dataset.pointerBound = 'true';

        let frame = 0;
        let rect: DOMRect | undefined;
        let pointerX = 0;
        let pointerY = 0;

        const updatePointerEffect = () => {
          frame = 0;
          if (!rect) return;

          const x = Math.min(Math.max(pointerX - rect.left, 0), rect.width);
          const y = Math.min(Math.max(pointerY - rect.top, 0), rect.height);
          const normalizedX = x / rect.width - 0.5;
          const normalizedY = y / rect.height - 0.5;

          card.style.setProperty('--project-pointer-x', `${x}px`);
          card.style.setProperty('--project-pointer-y', `${y}px`);
          card.style.setProperty('--project-rotate-x', `${(-normalizedY * 5).toFixed(2)}deg`);
          card.style.setProperty('--project-rotate-y', `${(normalizedX * 5).toFixed(2)}deg`);
          card.style.setProperty('--project-image-x', `${(-normalizedX * 8).toFixed(2)}px`);
          card.style.setProperty('--project-image-y', `${(-normalizedY * 8).toFixed(2)}px`);
        };

        card.addEventListener('pointerenter', () => {
          if (!finePointer.matches || reducedMotion.matches) return;
          rect = card.getBoundingClientRect();
          card.classList.add('is-pointer-active');
        });

        card.addEventListener('pointermove', (event) => {
          if (!finePointer.matches || reducedMotion.matches) return;
          pointerX = event.clientX;
          pointerY = event.clientY;
          if (!frame) frame = requestAnimationFrame(updatePointerEffect);
        }, { passive: true });

        const handlePointerEnd = () => {
          if (frame) cancelAnimationFrame(frame);
          frame = 0;
          rect = undefined;
          resetCard(card);
        };

        card.addEventListener('pointerleave', handlePointerEnd);
        card.addEventListener('pointercancel', handlePointerEnd);
      });
    }

    initProjectCards();
    document.addEventListener('astro:page-load', initProjectCards);
  })();
</script>
