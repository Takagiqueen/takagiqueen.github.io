---
import LeafVaultFeatureIcon from './LeafVaultFeatureIcon.astro';

const leafVaultFeatures = [
  {
    kind: 'security',
    title: '安全与隐私',
    description: '加密存储、安全登录、CORS/CSP、密文备份。',
    badge: 'Encrypted',
  },
  {
    kind: 'local',
    title: '本地优先 + PWA',
    description: 'IndexedDB 离线缓存、移动端适配、可安装。',
    badge: 'Offline',
  },
  {
    kind: 'deploy',
    title: '可部署可自托管',
    description: 'Docker 部署、pytest 测试、数据恢复与同步。',
    badge: 'Portable',
  },
] as const;
---

<section class="grid min-h-0 items-start gap-8 py-8 sm:py-14 lg:min-h-[calc(100vh-6rem)] lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:gap-10 lg:py-16">
  <div class="min-w-0">
    <p class="fade-up inline-flex max-w-full items-center gap-2 rounded-full border border-emerald-900/10 bg-white/60 px-4 py-2 text-sm text-emerald-800 shadow-sm backdrop-blur">
      <span class="size-2 rounded-full bg-emerald-500"></span>
      智能车辆工程 · Web 全栈 · LeafVault
    </p>

    <h1 class="fade-up fade-up-delay-1 mt-6 max-w-3xl break-all text-[clamp(2.15rem,10vw,3rem)] font-black leading-[0.98] tracking-tight text-emerald-950 sm:break-words sm:text-6xl lg:text-7xl">
      把想法，
      <br class="sm:hidden" />
      <span class="relative inline break-all sm:inline-block sm:break-words">
        做成发光的产品
<span class="absolute -bottom-2 left-0 hidden h-3 w-full rounded-full bg-emerald-200/70 -z-10 sm:block"></span>
      </span>
    </h1>

    <p class="fade-up fade-up-delay-2 mt-6 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-9">
      智能车辆工程专业学生，在学 Web 全栈和自动驾驶。
      从后端 API、数据库到前端、PWA 部署，一个人把 LeafVault 完整做了出来。
    </p>

    <div class="fade-up fade-up-delay-3 mt-8 flex flex-wrap gap-3">
      <a href="/projects/leafvault" class="rounded-full bg-emerald-950 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-900/15 transition hover:-translate-y-1 hover:bg-emerald-800">
        了解 LeafVault
      </a>
      <a href="/blog" class="rounded-full border border-emerald-900/10 bg-white/65 px-6 py-3 text-sm font-semibold text-emerald-900 shadow-sm backdrop-blur transition hover:-translate-y-1 hover:bg-white">
        阅读学习笔记
      </a>
    </div>
  </div>

  <div class="fade-up fade-up-delay-2 relative mx-auto mt-2 min-w-0 w-full max-w-full sm:max-w-lg lg:mt-0">
    <div class="relative overflow-hidden rounded-[2rem] border border-white/60 bg-gradient-to-br from-white/58 via-emerald-50/38 to-lime-50/28 p-4 shadow-[0_22px_70px_rgba(6,78,59,0.13)] ring-1 ring-white/50 backdrop-blur-2xl sm:p-5 sm:from-white/48 sm:via-emerald-50/30 sm:to-lime-50/20">
      <div class="absolute inset-x-0 top-0 h-24 overflow-hidden opacity-70">
        <div class="absolute -left-1/3 top-0 h-full w-2/3 skew-x-[-20deg] bg-white/40 blur-sm animate-[shimmer_5s_ease-in-out_infinite]"></div>
      </div>

      <div class="relative overflow-hidden rounded-[1.5rem] border border-white/50 bg-gradient-to-br from-white/38 via-emerald-50/24 to-sky-50/18 p-5 shadow-inner shadow-white/35 backdrop-blur-xl sm:p-6">
        <div class="pointer-events-none absolute -right-14 -top-16 size-40 rounded-full bg-emerald-200/25 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-16 left-4 size-36 rounded-full bg-sky-200/18 blur-3xl"></div>

        <div class="relative mb-6 flex flex-wrap items-start justify-between gap-4">
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-emerald-700/85">核心项目</p>
            <p class="mt-2 text-2xl font-black tracking-tight text-emerald-950">LeafVault</p>
            <p class="mt-2 max-w-sm text-sm leading-6 text-slate-600 sm:text-[15px]">
              一个本地优先、隐私友好的个人生活记录系统。
            </p>
          </div>
          <span class="rounded-full border border-emerald-900/10 bg-emerald-100/55 px-3 py-1 text-xs font-semibold text-emerald-800 shadow-sm backdrop-blur">全栈开发</span>
        </div>

        <div class="relative space-y-3">
          {leafVaultFeatures.map((feature) => (
            <div class="group/feature relative overflow-hidden rounded-[1.35rem] border border-white/50 bg-gradient-to-br from-white/36 via-emerald-50/24 to-lime-50/16 p-4 shadow-[0_10px_32px_rgba(6,78,59,0.08)] ring-1 ring-white/35 backdrop-blur-md transition duration-300 hover:-translate-y-1 hover:from-white/48 hover:via-emerald-50/34 hover:to-lime-50/24 hover:shadow-[0_16px_42px_rgba(6,78,59,0.12)]">
              <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-white/70"></div>
              <div class="relative flex items-start gap-4">
                <LeafVaultFeatureIcon kind={feature.kind} />
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="text-base font-bold leading-6 text-emerald-950">{feature.title}</p>
                    <span class="hidden rounded-full bg-emerald-950/5 px-2.5 py-0.5 text-[11px] font-semibold text-emerald-700 ring-1 ring-emerald-900/5 sm:inline-flex">
                      {feature.badge}
                    </span>
                  </div>
                  <p class="mt-1.5 text-sm leading-6 text-slate-600 sm:text-[15px] sm:leading-7">{feature.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
