---
import FallingLeaves from './FallingLeaves.astro';
---

<div aria-hidden="true" class="nature-background pointer-events-none fixed inset-0 z-0 overflow-hidden">
  <div class="nature-photo absolute inset-0"></div>
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.48)_0%,rgba(236,253,245,0.32)_42%,rgba(255,255,255,0.5)_100%)]"></div>
  <div class="absolute -left-24 top-10 h-72 w-72 rounded-full bg-sky-100/32 blur-3xl"></div>
  <div class="absolute right-[8%] top-24 h-80 w-80 rounded-full bg-lime-100/32 blur-3xl"></div>
  <div class="absolute bottom-[-8rem] left-[22%] h-96 w-96 rounded-full bg-emerald-100/28 blur-3xl"></div>
  <div class="nature-texture absolute inset-0"></div>
  <FallingLeaves />
</div>
