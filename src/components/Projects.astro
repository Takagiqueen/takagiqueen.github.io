---
import ProjectCard from './ProjectCard.astro';
import SectionTitle from './SectionTitle.astro';

const projects = [
  {
    title: 'LeafVault',
    description: '本地优先的个人生活记录应用。一个人做了后端 API、数据库、PWA、加密存储和 Docker 部署。',
    tags: ['FastAPI', 'SQLite', 'PWA', 'IndexedDB', 'Docker'],
    href: '/projects/leafvault',
    accent: 'from-emerald-100 via-lime-50 to-sky-100',
  },
  {
    title: '个人网站',
    description: '使用 Astro + Tailwind CSS + MDX 搭建，展示项目、博客与学习记录。',
    tags: ['Astro', 'Tailwind', 'TypeScript', 'MDX'],
    href: '/projects/personal-site',
    accent: 'from-sky-100 via-white to-emerald-100',
  },
  {
    title: 'Apollo 自动驾驶比赛',
    description: '参与 Apollo 自动驾驶仿真比赛，学习路径规划、控制算法与工程调试。',
    tags: ['Apollo', 'Python', 'C++', '仿真'],
    href: '/projects/autonomous-driving',
    accent: 'from-slate-100 via-white to-blue-100',
  },
];
---

<section class="py-16">
  <SectionTitle
    eyebrow="Projects"
    title="做过的项目"
    description="每个项目都整理了思路、技术选择和复盘笔记。"
  />

  <div class="grid gap-5 md:grid-cols-3">
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>
