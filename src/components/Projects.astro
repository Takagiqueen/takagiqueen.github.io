---
import ProjectCard from './ProjectCard.astro';
import SectionTitle from './SectionTitle.astro';

const projects = [
  {
    title: 'LeafVault',
    description: '本地优先的个人生活记录应用，围绕日记、账本、图片和生活日历做长期保存，重点解决离线可用、加密备份、云端密文同步和自托管部署问题。',
    tags: ['Local-first', 'IndexedDB', 'PWA', '加密备份', 'Docker'],
    href: '/projects/leafvault',
    accent: 'from-emerald-100 via-lime-50 to-sky-100',
  },
  {
    title: '个人网站',
    description: '使用 Astro + Tailwind CSS + MDX 搭建的个人作品集，用来展示项目复盘、学习路径和技术文章，同时实践 GitHub Pages 自动部署。',
    tags: ['Astro', 'Tailwind', 'MDX', 'GitHub Pages'],
    href: '/projects/personal-site',
    accent: 'from-sky-100 via-white to-emerald-100',
  },
  {
    title: 'Apollo 自动驾驶比赛',
    description: '参与 Apollo 自动驾驶仿真比赛，围绕路径规划、控制算法和场景调试进行工程实践，积累自动驾驶方向的项目经验。',
    tags: ['Apollo', '路径规划', '仿真', 'Python'],
    href: '/projects/autonomous-driving',
    accent: 'from-slate-100 via-white to-blue-100',
  },
];
---

<section class="py-16">
  <SectionTitle
    eyebrow="Projects"
    title="做过的项目"
    description="每个项目都整理了思路、技术选择和复盘笔记。"
  />

  <div class="grid gap-5 md:grid-cols-3">
    {projects.map((project) => <ProjectCard {...project} />)}
  </div>
</section>
