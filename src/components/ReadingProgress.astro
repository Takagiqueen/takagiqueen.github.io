<!-- 阅读进度条：页面顶部 3px 翠绿色细条，随滚动增长 -->
<div
  id="reading-progress"
  class="fixed inset-x-0 top-0 z-[60] h-[3px] bg-gradient-to-r from-emerald-400 via-emerald-500 to-emerald-600"
  style="transform-origin: left; transform: scaleX(0);"
></div>

<script>
  (function () {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    let ticking = false;

    function update() {
      const h = document.documentElement;
      const scrollTop = h.scrollTop || document.body.scrollTop;
      const scrollHeight = h.scrollHeight || document.body.scrollHeight;
      const clientHeight = h.clientHeight;
      const maxScroll = scrollHeight - clientHeight;

      if (maxScroll <= 0) {
        bar!.style.transform = 'scaleX(0)';
      } else {
        const progress = Math.min(scrollTop / maxScroll, 1);
        bar!.style.transform = `scaleX(${progress})`;
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });

    update();
  })();
</script>
