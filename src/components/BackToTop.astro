<!-- 回到顶部按钮：滚动超过 300px 后出现 -->
<button
  id="back-to-top"
  aria-label="回到顶部"
  class="pointer-events-none fixed bottom-6 right-6 z-40 grid size-11 place-items-center rounded-2xl border border-emerald-900/10 bg-white/55 text-emerald-700 opacity-0 shadow-[0_4px_20px_rgba(94,170,122,0.10)] backdrop-blur-lg transition-all duration-400 hover:bg-emerald-50 hover:text-emerald-900 hover:-translate-y-1 hover:shadow-[0_8px_28px_rgba(94,170,122,0.14)]"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<script>
  (function () {
    const btn = document.getElementById('back-to-top');
    if (!btn) return;

    let ticking = false;

    function update() {
      if (window.scrollY > 300) {
        btn!.classList.remove('pointer-events-none', 'opacity-0');
        btn!.classList.add('opacity-100');
      } else {
        btn!.classList.add('pointer-events-none', 'opacity-0');
        btn!.classList.remove('opacity-100');
      }
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });

    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
</script>
