---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目' },
  { href: '/blog', label: '博客' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-emerald-900/10 bg-white/55 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8 lg:px-10">
    <a href="/" class="group flex items-center gap-2 font-semibold tracking-tight text-emerald-950">
      <span class="grid size-9 place-items-center rounded-2xl bg-emerald-100 text-lg shadow-sm transition-transform duration-300 group-hover:-rotate-6 group-hover:scale-105">☘</span>
      <span>希儿的站点</span>
    </a>

    <div class="hidden items-center gap-1 rounded-full border border-emerald-900/10 bg-white/50 p-1 shadow-sm sm:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-4 py-2 text-sm text-slate-600 transition hover:bg-emerald-50 hover:text-emerald-800"
        >
          {item.label}
        </a>
      ))}
    </div>

    <a
      href="https://github.com/Takagiqueen?tab=repositories"
      target="_blank"
      rel="noreferrer"
      class="rounded-full border border-emerald-900/10 bg-emerald-950 px-4 py-2 text-sm font-medium text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-emerald-800"
    >
      My GitHub
    </a>
  </nav>
</header>
