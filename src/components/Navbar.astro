---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目' },
  { href: '/blog', label: '博客' },
  { href: '/about', label: '关于' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-emerald-900/10 bg-gradient-to-b from-white/50 via-white/40 to-white/25 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8 lg:px-10">
    <!-- 左侧 Logo -->
    <a href="/" class="group flex min-w-0 items-center gap-2 font-semibold tracking-tight text-emerald-950">
      <span class="grid size-9 place-items-center rounded-2xl bg-emerald-100 text-lg shadow-sm transition-transform duration-300 group-hover:-rotate-6 group-hover:scale-105">☘</span>
      <span class="truncate text-[17px]">希儿的站点</span>
    </a>

    <!-- 中间导航胶囊 — 桌面端 -->
    <div class="hidden items-center gap-2 rounded-full border border-emerald-900/10 bg-white/45 p-1.5 shadow-[0_2px_20px_rgba(94,170,122,0.07)] backdrop-blur-md sm:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-full px-5 py-2 text-[15px] font-medium transition-all duration-300',
            isActive(item.href)
              ? 'bg-emerald-100/60 text-emerald-800 shadow-sm'
              : 'text-slate-500 hover:bg-emerald-50 hover:text-emerald-800',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- 右侧 GitHub + 汉堡按钮 -->
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/Takagiqueen?tab=repositories"
        target="_blank"
        rel="noreferrer"
        class="hidden rounded-full border border-emerald-800/15 bg-emerald-950/85 px-4 py-2 text-sm font-medium text-white/95 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-0.5 hover:bg-emerald-900/90 hover:shadow-md sm:inline-flex"
      >
        My GitHub
      </a>

      <!-- 汉堡按钮 — 仅移动端 -->
      <button
        id="menu-toggle"
        class="group relative grid size-9 place-items-center rounded-xl border border-emerald-900/10 bg-white/50 backdrop-blur sm:hidden"
        aria-label="打开菜单"
        aria-expanded="false"
      >
        <span class="flex h-4 w-5 flex-col justify-between transition-all duration-300">
          <span class="block h-0.5 w-full rounded-full bg-emerald-800 transition-all duration-300 group-[.open]:translate-y-[7px] group-[.open]:rotate-45"></span>
          <span class="block h-0.5 w-full rounded-full bg-emerald-800 transition-all duration-300 group-[.open]:opacity-0"></span>
          <span class="block h-0.5 w-full rounded-full bg-emerald-800 transition-all duration-300 group-[.open]:-translate-y-[7px] group-[.open]:-rotate-45"></span>
        </span>
      </button>
    </div>
  </nav>

  <!-- 移动端下拉菜单 -->
  <div
    id="mobile-menu"
    class="pointer-events-none max-h-0 overflow-hidden border-b border-emerald-900/10 bg-gradient-to-b from-white/92 via-white/88 to-white/80 opacity-0 backdrop-blur-xl transition-all duration-300 sm:hidden"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-5 pb-4 pt-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-xl px-4 py-3 text-[15px] font-medium transition-all duration-300',
            isActive(item.href)
              ? 'bg-emerald-100/60 text-emerald-800'
              : 'text-slate-500 hover:bg-emerald-50 hover:text-emerald-800',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://github.com/Takagiqueen?tab=repositories"
        target="_blank"
        rel="noreferrer"
        class="rounded-xl bg-emerald-950/90 px-4 py-3 text-[15px] font-medium text-white/95 shadow-sm transition-all duration-300 hover:bg-emerald-900"
      >
        My GitHub
      </a>
    </div>
  </div>
</header>

<script>
  (function () {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    let open = false;

    toggle.addEventListener('click', () => {
      open = !open;
      toggle.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? '关闭菜单' : '打开菜单');

      if (open) {
        menu.classList.remove('pointer-events-none', 'max-h-0', 'opacity-0');
        menu.classList.add('max-h-96', 'opacity-100');
        document.body.classList.add('overflow-hidden');
      } else {
        menu.classList.add('pointer-events-none', 'max-h-0', 'opacity-0');
        menu.classList.remove('max-h-96', 'opacity-100');
        document.body.classList.remove('overflow-hidden');
      }
    });

    // 点击菜单内链接后自动关闭
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        open = false;
        toggle.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', '打开菜单');
        menu.classList.add('pointer-events-none', 'max-h-0', 'opacity-0');
        menu.classList.remove('max-h-96', 'opacity-100');
        document.body.classList.remove('overflow-hidden');
      });
    });
  })();
</script>
