---
interface Props {
  kind: 'security' | 'local' | 'deploy';
}

const { kind } = Astro.props;

const styles = {
  security: {
    tile: 'from-emerald-300/90 via-teal-100 to-lime-100/85',
    glow: 'bg-emerald-300/75',
    orb: 'bg-teal-400/70',
  },
  local: {
    tile: 'from-sky-300/85 via-cyan-100 to-emerald-100/85',
    glow: 'bg-sky-300/75',
    orb: 'bg-cyan-400/65',
  },
  deploy: {
    tile: 'from-lime-300/85 via-emerald-100 to-sky-100/85',
    glow: 'bg-lime-300/75',
    orb: 'bg-emerald-400/65',
  },
}[kind];
---

<span
  class={`relative grid size-10 shrink-0 place-items-center overflow-hidden rounded-2xl bg-gradient-to-br ${styles.tile} text-emerald-950 shadow-[0_10px_24px_rgba(6,78,59,0.12)] ring-1 ring-white/65 transition duration-300 group-hover/feature:-translate-y-0.5 group-hover/feature:scale-105 sm:size-11`}
  aria-hidden="true"
>
  <span class={`absolute -right-3 -top-3 size-7 rounded-full ${styles.glow} blur-md`}></span>
  <span class={`absolute -bottom-2 -left-2 size-6 rounded-full ${styles.orb} blur-sm`}></span>
  <span class="absolute inset-x-1.5 top-1 h-1/2 rounded-xl bg-white/30"></span>
  <span class="absolute inset-x-2 bottom-1 h-px bg-white/65"></span>
  <svg
    class="relative size-5 drop-shadow-[0_2px_5px_rgba(6,78,59,0.12)] sm:size-6"
    viewBox="0 0 24 24"
    fill="none"
  >
    {kind === 'security' && (
      <>
        <path d="M12 3.8 6.2 6.1v5.2c0 3.8 2.4 7 5.8 8.9 3.4-1.9 5.8-5.1 5.8-8.9V6.1L12 3.8Z" fill="currentColor" opacity="0.9" />
        <path d="m9.7 12.2 1.6 1.6 3.3-3.6" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="17" cy="6.4" r="1.4" fill="white" opacity="0.72" />
      </>
    )}

    {kind === 'local' && (
      <>
        <rect x="5" y="5.1" width="14" height="13.2" rx="3.8" fill="currentColor" opacity="0.9" />
        <path d="M8 9.1h8" stroke="white" stroke-width="1.8" stroke-linecap="round" opacity="0.78" />
        <path d="M8 12.1h5.4" stroke="white" stroke-width="1.8" stroke-linecap="round" opacity="0.56" />
        <circle cx="15.1" cy="15" r="2.35" fill="white" opacity="0.28" />
        <path d="m14 15 .8.8 1.7-2" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M7.4 3.9h9.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" opacity="0.5" />
      </>
    )}

    {kind === 'deploy' && (
      <>
        <path d="M8.2 17.2H7.1a3.5 3.5 0 0 1-.5-6.9 5.5 5.5 0 0 1 10.5-1.6 4.3 4.3 0 0 1 .6 8.5h-1.6" fill="currentColor" opacity="0.9" />
        <path d="M12 11.8v7" stroke="white" stroke-width="2.1" stroke-linecap="round" />
        <path d="m9.5 14.1 2.5-2.5 2.5 2.5" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M8.8 20h6.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" opacity="0.55" />
      </>
    )}
  </svg>
</span>
