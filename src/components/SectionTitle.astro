---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div data-reveal class="mb-8 max-w-2xl">
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700">{eyebrow}</p>}
  <h2 class="text-3xl font-bold tracking-tight text-emerald-950 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 leading-8 text-slate-600">{description}</p>}
</div>
