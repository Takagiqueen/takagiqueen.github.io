---
import { getCollection } from 'astro:content';
import SectionTitle from './SectionTitle.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="py-16">
  <SectionTitle
    eyebrow="Blog"
    title="最近的学习记录"
    description="博客用 MDX 管理，后续可以写 LeafVault 开发日志、Astro 建站记录、自动驾驶学习笔记。"
  />

  <div class="grid gap-5 md:grid-cols-3">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} data-reveal class="glass-card group rounded-[1.75rem] p-6 transition hover:-translate-y-2 hover:shadow-2xl hover:shadow-emerald-900/10">
        <p class="text-sm text-slate-500">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
        <h3 class="mt-4 text-xl font-bold text-emerald-950 group-hover:text-emerald-700">{post.data.title}</h3>
        <p class="mt-3 leading-7 text-slate-600">{post.data.description}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">{tag}</span>)}
        </div>
      </a>
    ))}
  </div>
</section>
